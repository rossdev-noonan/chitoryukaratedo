# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/blob-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code local settings (machine-specific permissions/runtime state)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# typescript
*.tsbuildinfo
next-env.d.ts

# working documents, not app source
/deliverables

# sanity CLI local runtime cache
.sanity

# Gil's raw high-res source images (Ross drops these locally for reference/export
# only — we pull in and optimize individual assets into public/images/, we don't
# commit the whole raw drop)
/OneDrive_1_7-20-2026
